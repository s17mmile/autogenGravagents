# Constants for the masses of the particles in kg
m1 = 1.67e-27  # mass of proton
m2 = 1.68e-27  # mass of neutron
m3 = 9.11e-31   # mass of electron

# Calculate total mass
M = m1 + m2 + m3

# Given net force
F_net = 32.0  # in Newtons

# Calculate acceleration of the center of mass
a_COM = F_net / M

# Print the result
print(f'The acceleration of the center of mass is approximately {a_COM:.2e} m/s^2')