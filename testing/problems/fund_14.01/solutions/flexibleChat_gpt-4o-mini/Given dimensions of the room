# Given dimensions of the room
length = 3.5  # in meters
width = 4.2   # in meters
height = 2.4  # in meters

g = 9.81  # gravitational constant in m/s^2

# Step 1: Calculate the volume of the room
volume = length * width * height  # in cubic meters

# Step 2: Determine the density of air at 1 atm
density_of_air = 1.225  # in kg/m^3

# Step 3: Calculate the mass of the air in the room
mass_of_air = density_of_air * volume  # in kg

# Step 4: Calculate the weight of the air
weight_of_air = mass_of_air * g  # in Newtons

# Outputs
print(f"Volume of the room: {volume:.2f} m³")
print(f"Mass of the air: {mass_of_air:.2f} kg")
print(f"Weight of the air: {weight_of_air:.2f} N")