# Constants
k = 8.99e9  # Coulomb's constant in N m^2/C^2

# Charges of the nuclei
charge_Th = 90 * 1.6e-19  # Charge of Th nucleus in C
charge_He = 2 * 1.6e-19   # Charge of He nucleus in C

# Separation distance
r = 9.0e-15  # Separation in meters

# Calculate the electrostatic force using Coulomb's law
# F = k * |q1 * q2| / r^2
F = k * abs(charge_Th * charge_He) / r**2

# Print the result with two significant figures
print(f'The electrostatic force between the nuclei is approximately {F:.1e} N')