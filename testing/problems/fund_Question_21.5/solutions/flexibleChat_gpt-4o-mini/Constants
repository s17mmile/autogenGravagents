# Constants
k = 8.99e9  # Coulomb's constant in N m^2/C^2
q1 = 3.00e-6  # Charge of particle 1 in C
q2 = -1.50e-6  # Charge of particle 2 in C
r = 0.12  # Distance between the charges in m

# Calculate the magnitude of the electrostatic force using Coulomb's Law
F = k * abs(q1 * q2) / r**2

# Output the result with three significant figures
print(f'The magnitude of the electrostatic force is {F:.3e} N')  # The force is attractive due to opposite charges.