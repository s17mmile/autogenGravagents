# Constants
m = 0.5  # mass of the potato in kg
k = 0.01  # air resistance coefficient in s^-1 (not used in this simplified model)
g = 9.81  # acceleration due to gravity in m/s^2
v0 = 120  # initial velocity in m/s

# Calculate maximum height using kinematic equation
# v^2 = u^2 + 2as, where v = 0 at maximum height
# 0 = v0^2 - 2gh_max => h_max = v0^2 / (2g)
h_max = (v0 ** 2) / (2 * g)
print(f'Maximum height reached by the potato: {h_max:.2f} meters')