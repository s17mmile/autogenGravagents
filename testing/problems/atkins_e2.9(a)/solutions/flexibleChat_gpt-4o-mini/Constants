# Constants
mass_argon = 12.0  # mass of argon in grams
molar_mass_argon = 39.95  # molar mass of argon in g/mol
V1 = 1.0  # initial volume in dm^3
V2 = 3.0  # final volume in dm^3
T1 = 273.15  # initial temperature in K
gamma = 1.67  # heat capacity ratio for argon

# Calculate final temperature using the adiabatic process formula
T2 = T1 * (V1 / V2) ** (gamma - 1)

# Output the final temperature with significant figures
print(f'The final temperature of the argon gas is approximately {T2:.3f} K (reported with three significant figures).')