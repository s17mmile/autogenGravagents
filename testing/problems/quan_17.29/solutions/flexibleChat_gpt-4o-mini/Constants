# Constants
E_H = -11.396  # AM1 valence electronic energy of H in eV
E_O = -316.100  # AM1 valence electronic energy of O in eV
E_H2O = -493.358  # AM1 valence electronic energy of H2O in eV
conversion_factor = 23.06  # eV to kcal/mol

# Calculate total energy of reactants
sum_E_reactants = 2 * E_H + E_O

# Calculate Delta H_f
Delta_H_f_eV = E_H2O - sum_E_reactants

# Convert to kcal/mol
Delta_H_f_kcal_mol = Delta_H_f_eV * conversion_factor

# Output the result
print(Delta_H_f_kcal_mol)